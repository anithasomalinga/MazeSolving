generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Score {
  id         Int      @id @default(autoincrement())
  name       String
  timeMs     Int
  difficulty String
  date       String
  createdAt  DateTime @default(now())

  @@index([date, difficulty])
}